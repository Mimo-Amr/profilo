{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "profilo",
  "compatibility_date": "2026-04-22",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "profile"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
{
  "d1_databases": [
    {
      "binding": "DB", 
      "database_name": "your-database-name",
      "database_id": "your-database-id"
    }
  ]
}
